{
  "name": "@chatter/server",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "prisma generate && tsc",
    "db:migrate": "prisma migrate deploy",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@chatter/shared": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^5",
    "supertest": "^7.2.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
